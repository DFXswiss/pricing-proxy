# CoinGecko Pro API key (https://www.coingecko.com/en/api/pricing).
# The proxy injects this as the `x-cg-pro-api-key` header on every
# CoinGecko upstream request, so the key lives here alone and never
# ships in consumer envs. GeckoTerminal is free-tier and needs no key.
COINGECKO_API_KEY=

# Quota monitor (optional). When both are set, the proxy probes the
# CoinGecko `/api/v3/key` endpoint every 30 min and pushes Telegram
# alerts when the monthly credit drops below 20% or 5% remaining. Leave
# empty to disable alerting — the proxy will keep serving requests.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
